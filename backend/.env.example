# MongoDB
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=branch_command_center

# JWT — change this to a strong random string in production
JWT_SECRET=change-me-to-a-strong-random-secret

# HRMS integration
HRMS_BASE_URL=http://<hrms-host>:<port>
HRMS_SYNC_MONTHS_BACKFILL=6

# Users who always use demo/mock data (comma-separated emails)
HRMS_DEMO_USERS=demo.user@company.com

# Email domains allowed to trigger live HRMS sync (comma-separated)
HRMS_LIVE_DOMAINS=yourdomain.com

# Credentials for IntegrationConfig.config.secret_ref = "NXZEN_MANAGER"
# The secret_ref name (NXZEN_MANAGER) must match what is stored in integration_configs
HRMS_SECRET_NXZEN_MANAGER_USERNAME=hr@yourdomain.com
HRMS_SECRET_NXZEN_MANAGER_PASSWORD=your-hrms-password
